# ----------------------------
# Large data (do not commit)
# ----------------------------
data/raw/*
data/derived/*
!data/raw/.gitkeep
!data/derived/.gitkeep

# Zipped source data (served via GitHub Releases)
*.csv.zip

# Model artifacts (served via GitHub Releases)
app/artifacts/*
!app/artifacts/.gitkeep
*.joblib

# ----------------------------
# Keep manuscript tables tracked
# ----------------------------
!tables/
!tables/*.csv

# ----------------------------
# Python
# ----------------------------
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/
env/
venv/

# ----------------------------
# OS / Editor
# ----------------------------
.DS_Store
.vscode/
